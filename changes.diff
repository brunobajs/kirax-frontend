+                    <td class="py-4 text-xs text-on-surface-variant">${d.categoria}</td>
+                    <td class="py-4 text-[10px] font-bold uppercase tracking-widest ${statusCol}">${d.status}</td>
+                </tr>
+             `;
+         }).join('') || '';
